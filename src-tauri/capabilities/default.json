{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:menu:default",
    "opener:default",
    "http:default",
    "http:allow-fetch",
    "shell:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://query1.finance.yahoo.com/*" },
        { "url": "https://query2.finance.yahoo.com/*" },
        { "url": "https://polling.finance.naver.com/*" }
      ]
    }
  ]
}
